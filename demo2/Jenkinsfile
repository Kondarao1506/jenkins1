pipeline{
    agent{
        label 'AGENT-1'
    }
    options{
        timeout(time: 1, unit: 'SECONDS')
    }
    stages{
        stage('Build'){
            steps{
                sh 'echo this is build'
                sleep(10)
            }
        }

         stage('Test'){
            steps{
                sh 'echo this is Test'
            }
        }

         stage('Deploy'){
            steps{
                sh 'echo this is deploy'
            }
        }
    }
post{
    always{
        echo "i am alsways executes"
        cleanWs()
    }
    failure{
        echo "i execute when i failed"
    }
    success{
        echo "sucesss"
    }
}
}